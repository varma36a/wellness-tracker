# ─── Single source of truth for Supabase config ───
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Edit .env.local with your keys from Supabase → Settings → API
# 3. Local dev reads .env.local automatically (npm run dev)
# 4. Deploy to Vercel from .env.local:  npm run env:sync-vercel && npm run deploy

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
